@model DATNSD54.DAO.DTO.CartDTO

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" />

    <style>
        /* Lớp làm mờ toàn bộ dòng */
        .cart-item-disabled {
            opacity: 0.6;
            background-color: #f8f9fa;
            /* pointer-events: none; /* Ngăn mọi thao tác click */
            position: relative;
        }

        /* Dòng chữ thông báo lỗi */
        .out-of-stock-label {
            color: #ee4d2d;
            font-weight: bold;
            font-size: 12px;
            display: block;
            margin-top: 5px;
        }
    </style>
}

<div class="cart">
    <div class="container">
        <div class="cart-wrap">
            <div class="cart-content">
                <div class="form-cart">
                    <div class="cart-body-left">
                        <div class="cart-heding hidden-xs">
                            <div class="row cart-row">
                                <div class="col-11" style="text-align: center;">
                                    <div class="row">
                                        <div class="col-5">Sản phẩm</div>
                                        <div class="col-2">Đơn giá</div>
                                        <div class="col-3">Số lượng</div>
                                        <div class="col-2">Thành tiền</div>
                                    </div>
                                </div>
                                <div class="col-1"></div>
                            </div>
                        </div>

                        <div class="cart-body">
                            @foreach (var item in Model.cartItems)
                            {
                                // Tính toán giá sau khi trừ sale 
                                var finalPrice = item.price - (item.price * item.sale / 100.0m);
                                var lineTotal = finalPrice * item.so_luong;
                                // Kiểm tra trạng thái ở đây
                                string disabledClass = !item.trangthai ? "cart-item-disabled" : "";
                                <div class="row cart-body-row cart-body-row-@item.id " style="align-items: center;">
                                    <div class="col-md-11 col-10 @disabledClass" style="text-align: center;">
                                        <div class="row card-info" style="align-items: center;">
                                            <div class="col-md-2 col-12 card-info-img">
                                                @if (item.UrlIMG != null)
                                                {
                                                    <a asp-controller="ProductDetail" asp-action="Index" asp-route-id="@item.product_id"><img class="cart-img" src="@Url.Content(item.UrlIMG)" alt="" style="width: 80px; border-radius: 5px;"></a>
                                                }
                                                else
                                                {
                                                    <a asp-controller="ProductDetail" asp-action="Index" asp-route-id="@item.product_id">
                                                    @* Ảnh dự phòng nếu DB không có ảnh nào *@
                                                    <img src="~/img/product/no-image.jpg"
                                                         width="300px"
                                                         height="auto"
                                                         class="big-img"
                                                         alt="không có ảnh"
                                                         id="img-main">
                                                    </a>
                                                }
                                            </div>
                                            <div class="col-md-3 col-12" style="text-align: left;">
                                                <div>
                                                    <a href="#" class="cart-name"><h5>@item.nameProduct</h5></a>
                                                    @if (!item.trangthai)
                                                    {
                                                        <span class="out-of-stock-label"><i class="fas fa-exclamation-triangle"></i> Sản phẩm hiện đã hết hàng hoặc không đủ tồn kho</span>
                                                    }
                                                </div>
                                                <div>
                                                    <a href="#" class="cart-name" style="text-decoration: none; color: #666; display: flex; align-items: center; gap: 8px;">
                                                        <h6 style="margin: 0; font-size: 13px;">Size: @item.Size</h6>
                                                        <div style="width: 12px; height: 12px; background-color: #@item.Color.Replace("#",""); border: 1px solid #000; box-sizing: border-box;"></div>
                                                        <span style="font-size: 11px;">(@item.Color)</span>
                                                    </a>
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-12" style="font-size: 16px;">
                                                <span>@finalPrice.ToString("N0")₫</span>
                                            </div>
                                            <div class="col-md-3 col-12">
                                                <div class="cart-quantity" style="display: flex; justify-content: center;">
                                                    @if(item.trangthai == true)
                                                    {
                                                        <input type="button" value="-" class="control" onclick="tru(@item.id)">
                                                        <input type="text" value="@item.so_luong" onchange="nhapSo(@item.id,this)" class="text-input" id="text_so_luong-@item.id" style="width: 40px; text-align: center;">
                                                        <input type="button" value="+" class="control" onclick="cong(@item.id)">
                                                    }
                                                    else
                                                    {
                                                        <input type="button" value="-" class="control" disabled>
                                                        <input type="text" value="@item.so_luong" class="text-input" disabled style="width: 40px; text-align: center;">
                                                        <input type="button" value="+" class="control" disabled>
                                                    }
                                                </div>
                                            </div>
                                            <div class="col-md-2 col-12 hidden-xs" style="font-size: 16px; font-weight: bold; color: #ee4d2d;">
                                                <span id="line-total-@item.id">@lineTotal.ToString("N0")₫</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-1 col-2 text-right" style="pointer-events: auto; opacity:1;">
                                        <a href="#" onclick="xoa(@item.id)" style="color: red;"><i class="fas fa-trash"></i></a>
                                    </div>
                                </div>

                            }
                        </div>

                        <div class="cart-footer">
                            <div class="row cart-footer-row">
                                <div class="col-1"></div>
                                <div class="col-11 continue">
                                    <a href="/">
                                        <i class="fas fa-chevron-left"></i> Tiếp tục mua sắm
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="cart-body-right">
                        <div class="cart-total">
                            <label for="">Thành tiền:</label>
                            @* Tính tổng tất cả sản phẩm *@
                            @{
                                var grandTotal = Model.cartItems.Sum(x => (x.price - (x.price * x.sale / 100m)) * x.so_luong);
                            }
                            <span class="total__price" id="grand-total" style="font-size: 20px; color: #ee4d2d; font-weight: bold;">@grandTotal.ToString("N0")₫</span>
                        </div>
                        <div class="cart-buttons">

                            <form asp-controller="Pay" asp-action="CreateBill" method="post" id="formCreateBill">
                                <button type="button"
                                        style="display: block; width: 100%; border: none; text-align: center; background: #ee4d2d; color: white; padding: 10px; text-decoration: none; font-weight: bold; cursor: pointer;"
                                        onclick="this.form.submit();"
                                        class="chekout">
                                    THANH TOÁN
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
   
}