@model IEnumerable<DATNSD54.DAO.Models.VoucherShip>

@{
    ViewData["Title"] = "Danh sách Voucher Vận chuyển";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Quản lý Voucher Vận chuyển</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Tạo mới Voucher
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Mã (ID)</th>
                <th>Tên Voucher</th>
                <th>Đơn tối thiểu</th>
                <th>Số lượng</th>
                <th>Giới hạn sử dụng</th>
                <th>Bắt đầu</th>
                <th>Kết thúc</th>
                <th>Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.ID</strong></td>
                    <td>@item.Ten</td>
                    <td>@item.Don_Hang_Toi_Thieu.ToString("N0") VNĐ</td>
                    <td>@item.So_Luong</td>
                    <td>@item.Gioi_Han_Su_Dung</td>
                    <td>@item.Ngay_Bat_Dau.ToString("dd/MM/yyyy")</td>
                    <td>@item.Ngay_Ket_Thuc.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (item.Trang_Thai == 1)
                        {
                            <span class="badge bg-success">Đang áp dụng</span>
                        }
                        else if (item.Trang_Thai == 0)
                        {
                            <span class="badge bg-secondary">Ngừng áp dụng</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Hết hạn</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Details" asp-route-id="@item.ID" class="btn btn-sm btn-info">Chi tiết</a>
                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>