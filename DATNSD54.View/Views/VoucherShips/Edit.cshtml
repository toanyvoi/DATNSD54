@model DATNSD54.DAO.Models.VoucherShip

@{
    ViewData["Title"] = "Chỉnh sửa Voucher Ship";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-white">
            <h4 class="mb-0">Chỉnh sửa Voucher Vận chuyển: @Model.ID</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="ID" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mã Voucher (ID)</label>
                        <input class="form-control bg-light" value="@Model.ID" disabled />
                        <small class="text-muted">Không thể thay đổi mã định danh.</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Tên Voucher</label>
                        <input asp-for="Ten" class="form-control" />
                        <span asp-validation-for="Ten" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Đơn tối thiểu (VNĐ)</label>
                        <input asp-for="Don_Hang_Toi_Thieu" type="number" class="form-control" />
                        <span asp-validation-for="Don_Hang_Toi_Thieu" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Số lượng lượt dùng</label>
                        <input asp-for="So_Luong" type="number" class="form-control" />
                        <span asp-validation-for="So_Luong" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Giới Hạn sử dụng trên từng tk</label>
                        <input asp-for="Gioi_Han_Su_Dung" type="number" class="form-control" />
                        <span asp-validation-for="Gioi_Han_Su_Dung" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ngày bắt đầu</label>
                        <input asp-for="Ngay_Bat_Dau" type="datetime-local" class="form-control"
                               value="@Model.Ngay_Bat_Dau.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="Ngay_Bat_Dau" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Ngày kết thúc</label>
                        <input asp-for="Ngay_Ket_Thuc" type="datetime-local" class="form-control"
                               value="@Model.Ngay_Ket_Thuc.ToString("yyyy-MM-ddTHH:mm")" />
                        <span asp-validation-for="Ngay_Ket_Thuc" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="Trang_Thai" class="form-select">
                        <option value="1">Đang áp dụng</option>
                        <option value="0">Ngừng áp dụng</option>
                        
                    </select>
                    <span asp-validation-for="Trang_Thai" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-warning px-4 text-dark fw-bold">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}