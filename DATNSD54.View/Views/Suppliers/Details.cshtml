@model DATNSD54.DAO.Models.Supplier

@{
    ViewData["Title"] = "Chi tiết Nhà cung cấp";
}

@section Styles {
    <style>
        .admin-details-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 50px 0;
        }

        .details-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .details-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
        }

        .details-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 30px;
        }

        .header-main {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .header-icon {
            width: 55px;
            height: 55px;
            background: #f0f2f5;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2c3e50;
            font-size: 22px;
        }

        .header-title h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #2c3e50;
            margin: 0;
        }

        .divider {
            height: 1px;
            background: linear-gradient(90deg, #e8ecef, transparent);
            margin: 25px 0;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 35px;
        }

        .detail-item {
            padding: 15px;
            background: #fcfdfe;
            border-radius: 12px;
            border: 1px solid #f1f4f8;
        }

        .full-width { grid-column: span 2; }

        .label-text {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: #bdc3c7;
            text-transform: uppercase;
            margin-bottom: 5px;
        }

        .value-text {
            display: block;
            font-size: 1.05rem;
            font-weight: 600;
            color: #2c3e50;
        }

        .value-text a {
            color: #2c3e50;
            text-decoration: none;
        }

        .value-text a:hover {
            color: #007bff;
            text-decoration: underline;
        }

        .status-badge {
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .status-active   { background: #e6f7ee; color: #27ae60; }
        .status-inactive { background: #fff5f5; color: #e74c3c; }

        .action-group {
            display: flex;
            gap: 12px;
        }

        .btn-edit-mode {
            flex: 2;
            background: #2c3e50;
            color: white;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-edit-mode:hover {
            background: #1a252f;
            color: white;
            transform: translateY(-2px);
        }

        .btn-back {
            flex: 1;
            background: #f8f9fa;
            color: #7f8c8d;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            border: 1px solid #e8ecef;
            transition: all 0.3s ease;
        }

        .btn-back:hover {
            background: #eef2f7;
            color: #2c3e50;
        }
    </style>
}

<div class="admin-details-page">
    <div class="details-container">
        <div class="details-card">
            <div class="details-header">
                <div class="header-main">
                    <div class="header-icon">
                        <i class="fas fa-truck"></i>
                    </div>
                    <div class="header-title">
                        <h2>Chi tiết Nhà cung cấp</h2>
                        <p class="text-muted mb-0">ID: #@Model.Id</p>
                    </div>
                </div>
                <div>
                    @if (Model.Trang_Thai == true)
                    {
                        <span class="status-badge status-active">Hoạt động</span>
                    }
                    else
                    {
                        <span class="status-badge status-inactive">Ngừng</span>
                    }
                </div>
            </div>

            <div class="divider"></div>

            <div class="detail-grid">
                <div class="detail-item full-width">
                    <span class="label-text">Tên nhà cung cấp</span>
                    <span class="value-text">@Html.DisplayFor(model => model.Ten)</span>
                </div>
                <div class="detail-item">
                    <span class="label-text">Số điện thoại</span>
                    <span class="value-text">
                        <a href="tel:@Model.SDT">@Html.DisplayFor(model => model.SDT)</a>
                    </span>
                </div>
                <div class="detail-item">
                    <span class="label-text">Email</span>
                    <span class="value-text">
                        <a href="mailto:@Model.Email">@Html.DisplayFor(model => model.Email)</a>
                    </span>
                </div>
                <div class="detail-item full-width">
                    <span class="label-text">Địa chỉ</span>
                    <span class="value-text">@Html.DisplayFor(model => model.Dia_Chi)</span>
                </div>
                <div class="detail-item full-width">
                    <span class="label-text">Ngày tạo</span>
                    <span class="value-text">@Model.Ngay_Tao.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <div class="action-group">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit-mode">
                    <i class="fas fa-edit"></i> Chỉnh sửa
                </a>
                <a asp-action="Index" class="btn-back">Quay lại danh sách</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        console.log("Details page loaded for Supplier ID: @Model.Id");
    </script>
}