@model IEnumerable<DATNSD54.DAO.Models.Brand>

@{
    ViewData["Title"] = "Quản lý Thương hiệu";
}

@section Styles {
    <style>
        .admin-index-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 40px 0;
        }

        .index-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .index-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            padding: 30px;
        }

        .index-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .index-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2c3e50;
            margin: 0;
        }

        .btn-create-brand {
            background: #2c3e50;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-create-brand:hover {
            background: #1a252f;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 62, 80, 0.2);
        }

        /* Table Styling */
        .brand-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 10px;
        }

        .brand-table thead th {
            background: transparent;
            color: #95a5a6;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 10px 15px;
            border: none;
        }

        .brand-table tbody tr {
            background: #fcfdfe;
            transition: all 0.3s ease;
        }

        .brand-table tbody td {
            padding: 15px;
            vertical-align: middle;
            border-top: 1px solid #f1f4f8;
            border-bottom: 1px solid #f1f4f8;
        }

        .brand-table tbody td:first-child {
            border-left: 1px solid #f1f4f8;
            border-radius: 12px 0 0 12px;
        }

        .brand-table tbody td:last-child {
            border-right: 1px solid #f1f4f8;
            border-radius: 0 12px 12px 0;
        }

        .brand-table tbody tr:hover {
            transform: scale(1.01);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            background: white;
        }

        /* Logo Styling */
        .brand-logo-circle {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            object-fit: contain;
            background: white;
            padding: 3px;
            border: 1px solid #edf2f7;
        }

        .brand-name {
            font-weight: 700;
            color: #2c3e50;
            font-size: 1rem;
        }

        /* Status Badge */
        .badge-status {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .status-on { background: #e8f5e9; color: #2e7d32; }
        .status-off { background: #ffebee; color: #c62828; }

        /* Action Buttons */
        .action-group {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

        .btn-action {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-edit { background: #f0f7ff; color: #007bff; }
        .btn-details { background: #f8f9fa; color: #6c757d; }
        .btn-delete { background: #fff5f5; color: #e74c3c; }

        .btn-edit:hover { background: #007bff; color: white; }
        .btn-details:hover { background: #6c757d; color: white; }
        .btn-delete:hover { background: #e74c3c; color: white; }
    </style>
}

<div class="admin-index-page">
    <div class="index-container">
        <div class="index-card">
            <div class="index-header">
                <h2 class="index-title">Danh mục Thương hiệu</h2>
                <a asp-action="Create" class="btn-create-brand">
                    <i class="fas fa-plus-circle"></i> Thêm mới
                </a>
            </div>

            <div class="table-responsive">
                <table class="brand-table">
                    <thead>
                        <tr>
                            <th width="80">Logo</th>
                            <th>@Html.DisplayNameFor(model => model.Ten)</th>
                            <th>@Html.DisplayNameFor(model => model.NgayTao)</th>
                            <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                            <th class="text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.LogoUrl))
                                    {
                                        <img src="@Url.Content(item.LogoUrl)" class="brand-logo-circle" alt="logo" />
                                    }
                                    else
                                    {
                                        <div class="brand-logo-circle d-flex align-items-center justify-content-center">
                                            <i class="fas fa-box text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="brand-name">@item.Ten</span>
                                </td>
                                <td>
                                    <span class="text-muted"><i class="far fa-calendar-alt mr-1"></i> @item.NgayTao?.ToString("dd/MM/yyyy")</span>
                                </td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge-status status-on"><i class="fas fa-check mr-1"></i> Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status status-off"><i class="fas fa-pause mr-1"></i> Tạm ngưng</span>
                                    }
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" title="Sửa">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details" title="Chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Khởi tạo tooltip hoặc các hiệu ứng bảng nếu cần
        });
    </script>
}