@model DATNSD54.DAO.Models.Brand

@{
    ViewData["Title"] = "Chi tiết Thương hiệu";
}

@section Styles {
    <style>
        .admin-details-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 50px 0;
        }

        .details-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .details-card {
            background: white;
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
            position: relative;
            overflow: hidden;
        }

        /* Decorative element */
        .details-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 8px;
            background: linear-gradient(90deg, #2c3e50, #000);
        }

        .details-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
        }

        .brand-identity {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .brand-logo-wrapper {
            width: 80px;
            height: 80px;
            background: #fff;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid #f1f4f8;
            padding: 10px;
        }

        .brand-logo-wrapper img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .brand-info-title h2 {
            font-size: 1.6rem;
            font-weight: 800;
            color: #2c3e50;
            margin: 0;
        }

        .brand-info-title p {
            color: #95a5a6;
            margin: 0;
            font-size: 0.9rem;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 25px;
            margin-bottom: 40px;
        }

        .info-item {
            padding: 20px;
            background: #fcfdfe;
            border-radius: 16px;
            border: 1px solid #f1f4f8;
            transition: all 0.3s ease;
        }

        .info-item:hover {
            background: #fff;
            box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        }

        .full-width {
            grid-column: span 2;
        }

        .label-text {
            display: block;
            font-size: 0.75rem;
            font-weight: 700;
            color: #bdc3c7;
            text-transform: uppercase;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .value-text {
            display: block;
            font-size: 1.1rem;
            font-weight: 600;
            color: #2c3e50;
        }

        /* Status Badge */
        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .status-active { background: #e8f5e9; color: #2e7d32; }
        .status-inactive { background: #ffebee; color: #c62828; }

        /* Action Buttons */
        .action-group {
            display: flex;
            gap: 15px;
        }

        .btn-edit-main {
            flex: 2;
            background: #2c3e50;
            color: white;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-edit-main:hover {
            background: #1a252f;
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .btn-back-list {
            flex: 1;
            background: #f8f9fa;
            color: #7f8c8d;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            text-align: center;
            text-decoration: none;
            border: 1px solid #e8ecef;
            transition: all 0.2s;
        }

        .btn-back-list:hover {
            background: #e9ecef;
            color: #2c3e50;
        }
    </style>
}

<div class="admin-details-page">
    <div class="details-container">
        <div class="details-card">
            <div class="details-header">
                <div class="brand-identity">
                    <div class="brand-logo-wrapper">
                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                        {
                            <img src="@Model.LogoUrl" alt="@Model.Ten" />
                        }
                        else
                        {
                            <i class="fas fa-briefcase fa-2x text-light"></i>
                        }
                    </div>
                    <div class="brand-info-title">
                        <h2>@Model.Ten</h2>
                        <p>Thông tin định danh thương hiệu</p>
                    </div>
                </div>
                <div>
                    @if (Model.TrangThai)
                    {
                        <div class="status-indicator status-active">
                            <i class="fas fa-check-circle"></i> Đang hoạt động
                        </div>
                    }
                    else
                    {
                        <div class="status-indicator status-inactive">
                            <i class="fas fa-times-circle"></i> Tạm ngưng
                        </div>
                    }
                </div>
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <span class="label-text">@Html.DisplayNameFor(model => model.Ten)</span>
                    <span class="value-text">@Model.Ten</span>
                </div>

                <div class="info-item">
                    <span class="label-text">@Html.DisplayNameFor(model => model.NgayTao)</span>
                    <span class="value-text">@Model.NgayTao?.ToString("dd/MM/yyyy")</span>
                </div>

                <div class="info-item full-width">
                    <span class="label-text">@Html.DisplayNameFor(model => model.LogoUrl)</span>
                    <span class="value-text text-muted" style="font-size: 0.9rem; word-break: break-all;">
                        <i class="fas fa-link mr-2"></i> @Model.LogoUrl
                    </span>
                </div>

                <div class="info-item full-width">
                    <span class="label-text">Trạng thái hệ thống</span>
                    <span class="value-text">
                        @(Model.TrangThai ? "Thương hiệu hiện đang hiển thị trên cửa hàng và cho phép liên kết sản phẩm." : "Thương hiệu đang bị ẩn và không thể sử dụng cho sản phẩm mới.")
                    </span>
                </div>
            </div>

            <div class="action-group">
                <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-edit-main">
                    <i class="fas fa-edit"></i> Chỉnh sửa thông tin
                </a>
                <a asp-action="Index" class="btn-back-list">
                    Trở về danh sách
                </a>
            </div>
        </div>
    </div>
</div>