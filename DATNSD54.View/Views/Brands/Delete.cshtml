@model DATNSD54.DAO.Models.Brand

@{
    ViewData["Title"] = "Xóa Thương hiệu";
}

@section Styles {
    <style>
        .admin-delete-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 60px 0;
        }

        .delete-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .delete-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
            border-top: 5px solid #e74c3c;
        }

        .delete-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .warning-icon {
            width: 70px;
            height: 70px;
            background: #fff5f5;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .warning-icon i {
            font-size: 30px;
            color: #e74c3c;
        }

        .delete-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2c3e50;
        }

        /* Brand Preview Box */
        .brand-preview-box {
            background: #f8f9fa;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            text-align: center;
        }

        .brand-logo-img {
            max-width: 120px;
            height: auto;
            border-radius: 10px;
            margin-bottom: 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            background: white;
            padding: 10px;
        }

        .info-list {
            text-align: left;
            margin-top: 20px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #edf2f7;
        }

        .info-label {
            font-weight: 700;
            color: #95a5a6;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        .info-value {
            font-weight: 600;
            color: #2c3e50;
        }

        .btn-delete-confirm {
            background: #e74c3c;
            border: none;
            color: white;
            padding: 15px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
            font-size: 1.1rem;
        }

        .btn-delete-confirm:hover {
            background: #c0392b;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(231, 76, 60, 0.3);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #95a5a6;
            text-decoration: none;
            font-weight: 500;
        }

        .back-link:hover { color: #2c3e50; }
    </style>
}

<div class="admin-delete-page">
    <div class="delete-container">
        <div class="delete-card">
            <div class="delete-header">
                <div class="warning-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h2 class="delete-title">Xóa Thương Hiệu?</h2>
                <p class="text-muted">Bạn có chắc chắn muốn xóa thương hiệu này khỏi hệ thống?</p>
            </div>

            <div class="brand-preview-box">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" class="brand-logo-img" alt="@Model.Ten" />
                }
                else
                {
                    <div class="brand-logo-img d-flex align-items-center justify-content-center mx-auto">
                        <i class="fas fa-image text-muted fa-2x"></i>
                    </div>
                }

                <h3 class="h5 font-weight-bold mb-0">@Model.Ten</h3>

                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">@Html.DisplayNameFor(model => model.NgayTao)</span>
                        <span class="info-value">@Model.NgayTao?.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">@Html.DisplayNameFor(model => model.TrangThai)</span>
                        <span class="info-value">
                            @if (Model.TrangThai)
                            {
                                <span class="badge badge-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Tạm ngưng</span>
                            }
                        </span>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-delete-confirm">
                    <i class="fas fa-trash-alt mr-2"></i> Xác nhận xóa vĩnh viễn
                </button>
            </form>

            <a asp-action="Index" class="back-link">
                <i class="fas fa-times mr-1"></i> Hủy và quay lại
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.btn-delete-confirm').click(function() {
            return confirm("Lưu ý: Xóa thương hiệu có thể ảnh hưởng đến các sản phẩm liên quan. Bạn vẫn muốn tiếp tục?");
        });
    </script>
}