<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function showPage(pageId, el) {
    document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    var target = document.getElementById('page-' + pageId);
    if (target) target.classList.add('active');
    if (el) el.classList.add('active');
    return false;
  }

  // ===== FILTER TABLE CHUNG =====
  function filterTable(tbodyId, keyword) {
    var kw = keyword.toLowerCase();
    document.querySelectorAll('#' + tbodyId + ' tr').forEach(function(tr) {
      tr.style.display = tr.innerText.toLowerCase().includes(kw) ? '' : 'none';
    });
  }

  // ===== TẠO ĐƠN HÀNG =====
  var gioHang = [];

  function filterSanPham() {
    var kw = document.getElementById('spSearchInput').value.toLowerCase();
    document.querySelectorAll('#spTbody tr').forEach(function(tr) {
      tr.style.display = tr.dataset.ten.toLowerCase().includes(kw) ? '' : 'none';
    });
  }

  function themVaoGio(ma, ten, gia) {
    var idx = gioHang.findIndex(function(x) { return x.ma === ma; });
    if (idx >= 0) {
      gioHang[idx].qty++;
    } else {
      gioHang.push({ ma: ma, ten: ten, gia: gia, qty: 1 });
    }
    renderGio();
  }

  function renderGio() {
    var list = document.getElementById('gioHangList');
    var badge = document.getElementById('gioBadge');
    var trong = document.getElementById('gioTrong');
    badge.textContent = gioHang.reduce(function(s, x) { return s + x.qty; }, 0);
    if (gioHang.length === 0) {
      list.innerHTML = '<p class="text-muted" style="font-size:13px;font-style:italic;" id="gioTrong">Chưa có sản phẩm nào</p>';
      tinhTong(); return;
    }
    var html = '';
    gioHang.forEach(function(item, i) {
      html += '<div class="gio-hang-item">'
        + '<div class="sp-name">' + item.ten + '</div>'
        + '<input class="sp-qty" type="number" min="1" value="' + item.qty + '" onchange="doiSoLuong(' + i + ',this.value)">'
        + '<div class="sp-price">' + formatMoney(item.gia * item.qty) + '</div>'
        + '<button class="rm-btn" onclick="xoaKhoiGio(' + i + ')"><i class="bi bi-x-circle"></i></button>'
        + '</div>';
    });
    list.innerHTML = html;
    tinhTong();
  }

  function doiSoLuong(i, val) {
    gioHang[i].qty = parseInt(val) || 1;
    renderGio();
  }
  function xoaKhoiGio(i) {
    gioHang.splice(i, 1);
    renderGio();
  }

  function tinhTong() {
    var tam = gioHang.reduce(function(s, x) { return s + x.gia * x.qty; }, 0);
    var giam = parseInt(document.getElementById('giamGia') && document.getElementById('giamGia').value) || 0;
    var ship = parseInt(document.getElementById('phiShip') && document.getElementById('phiShip').value) || 0;
    var tong = tam - giam + ship;
    if (tong < 0) tong = 0;
    document.getElementById('tamTinh').textContent = formatMoney(tam);
    document.getElementById('tongCong').textContent = formatMoney(tong);
    tinhTra();
  }

  function tinhTra() {
    var tongEl = document.getElementById('tongCong');
    var tong = parseMoney(tongEl ? tongEl.textContent : '0');
    var dua = parseInt(document.getElementById('khachDua') && document.getElementById('khachDua').value) || 0;
    var thoi = dua - tong;
    document.getElementById('tienThoi').textContent = formatMoney(thoi >= 0 ? thoi : 0);
  }

  function xuLyDon() {
    if (gioHang.length === 0) { alert('Vui lòng thêm sản phẩm vào giỏ hàng!'); return; }
    if (confirm('Xác nhận tạo đơn hàng?')) {
      alert('Đơn hàng đã được tạo thành công!');
      gioHang = [];
      renderGio();
      document.getElementById('giamGia').value = '';
      document.getElementById('phiShip').value = '';
      document.getElementById('khachDua').value = '';
    }
  }

  function formatMoney(n) {
    return (n || 0).toLocaleString('vi-VN') + 'đ';
  }
  function parseMoney(s) {
    return parseInt((s || '0').replace(/[^\d]/g, '')) || 0;
  }

  // ===== CHART TRANG CHỦ =====
  (function () {
    var ctx = document.getElementById('chartDoanhSo');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
        datasets: [{ label: 'Doanh số', data: [0,0,0,0,0,0,0], backgroundColor: 'rgba(41,128,185,0.72)', borderColor: '#2471a3', borderWidth: 1, borderRadius: 3 }]
      },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { font: { size: 11 } } }, x: { ticks: { font: { size: 11 } } } } }
    });
  })();

  // ===== CHART DOANH SỐ =====
  var chartDS, chartPie;
  var dsData = {
    tuan: { labels: ['T2','T3','T4','T5','T6','T7','CN'], data: [12500000,8300000,15700000,9200000,21000000,18400000,6800000] },
    thang: { labels: ['T1','T2','T3','T4','T5','T6','T7','T8','T9','T10','T11','T12'], data: [85e6,92e6,78e6,105e6,115e6,98e6,120e6,88e6,75e6,110e6,95e6,130e6] },
    quy: { labels: ['Quý 1','Quý 2','Quý 3','Quý 4'], data: [255e6,318e6,283e6,335e6] }
  };

  function capNhatBieuDo() {
    var ky = document.getElementById('dsKySelect').value;
    var d = dsData[ky];
    if (chartDS) {
      chartDS.data.labels = d.labels;
      chartDS.data.datasets[0].data = d.data;
      chartDS.update();
    }
  }

  (function initDSChart() {
    var ctx1 = document.getElementById('chartDS');
    if (!ctx1) return;
    chartDS = new Chart(ctx1, {
      type: 'bar',
      data: {
        labels: dsData.tuan.labels,
        datasets: [{
          label: 'Doanh thu (đ)', data: dsData.tuan.data,
          backgroundColor: 'rgba(36,113,163,0.75)', borderColor: '#1a5276', borderWidth: 1, borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(c) { return ' ' + c.raw.toLocaleString('vi-VN') + 'đ'; } } } },
        scales: { y: { beginAtZero: true, ticks: { font: { size: 11 }, callback: function(v) { return (v/1e6).toFixed(0) + 'tr'; } } }, x: { ticks: { font: { size: 11 } } } }
      }
    });

    var ctx2 = document.getElementById('chartPie');
    if (!ctx2) return;
    chartPie = new Chart(ctx2, {
      type: 'doughnut',
      data: {
        labels: ['Điện thoại', 'Phụ kiện', 'Laptop', 'Khác'],
        datasets: [{ data: [65, 20, 10, 5], backgroundColor: ['#2471a3','#27ae60','#e67e22','#8e44ad'], borderWidth: 2 }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } } }
    });
  })();
</script>
