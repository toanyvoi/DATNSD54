@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Phần mềm quản lý bán hàng</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, sans-serif; background: #f4f4f4; }

    /* ===== TOPBAR ===== */
    #topbar {
      position: fixed; top: 0; left: 0; right: 0;
      height: 48px;
      background: linear-gradient(90deg, #2471a3, #1a5276);
      display: flex; align-items: center;
      padding: 0 18px;
      z-index: 1000;
      gap: 10px;
    }
    .topbar-brand { color: #fff; font-size: 15px; font-weight: 700; }
    .topbar-right { margin-left: auto; display: flex; align-items: center; gap: 10px; }
    .topbar-label { color: #d6eaf8; font-size: 13px; }
    .topbar-select {
      border: 1px solid rgba(255,255,255,.4);
      background: rgba(255,255,255,.15);
      color: #fff; border-radius: 4px;
      padding: 3px 10px; font-size: 13px; outline: none;
    }
    .topbar-select option { color: #333; background: #fff; }
    .topbar-btn {
      color: #fff; font-size: 13px;
      background: rgba(255,255,255,.15);
      border: 1px solid rgba(255,255,255,.3);
      border-radius: 4px; padding: 4px 14px;
      cursor: pointer; user-select: none;
    }
    .topbar-btn:hover { background: rgba(255,255,255,.28); }

    /* ===== SIDEBAR ===== */
    #sidebar {
      position: fixed; top: 48px; left: 0;
      width: 175px; height: calc(100vh - 48px);
      background: #2c3e50; overflow-y: auto; z-index: 900;
    }
    #sidebar::-webkit-scrollbar { width: 4px; }
    #sidebar::-webkit-scrollbar-thumb { background: #3d5166; }

    .nav-item {
      display: flex; align-items: center; gap: 9px;
      padding: 11px 15px; color: #bdc3c7;
      text-decoration: none; font-size: 13.5px;
      border-bottom: 1px solid rgba(255,255,255,.04);
      transition: background .15s, color .15s; cursor: pointer;
    }
    .nav-item i { font-size: 15px; width: 18px; text-align: center; flex-shrink: 0; }
    .nav-item:hover { background: #3d5166; color: #fff; text-decoration: none; }
    .nav-item.active { background: #27ae60; color: #fff; }

    /* ===== MAIN ===== */
    #main { margin-left: 175px; margin-top: 48px; padding: 16px; min-height: calc(100vh - 48px); }

    .page-section { display: none; }
    .page-section.active { display: block; }

    /* ===== TODAY BADGE ===== */
    .today-header { text-align: center; margin-bottom: 14px; }
    .badge-today {
      display: inline-flex; align-items: center; gap: 7px;
      background: #eaf4fb; border: 1px solid #aed6f1;
      color: #1a5276; border-radius: 4px;
      padding: 5px 18px; font-size: 13px; font-weight: 600;
    }

    /* ===== STAT CARDS ===== */
    .stat-card {
      border-radius: 5px; color: #fff;
      padding: 14px 16px;
      display: flex; align-items: center; gap: 14px;
      min-height: 74px;
    }
    .stat-card .stat-icon { font-size: 30px; opacity: .85; flex-shrink: 0; }
    .stat-card .stat-label { font-size: 13px; opacity: .92; font-weight: 500; }
    .stat-card .stat-sub { font-size: 12px; opacity: .85; }
    .stat-card .stat-value { font-size: 26px; font-weight: 700; line-height: 1.1; }
    .bg-green  { background: #27ae60; }
    .bg-blue   { background: #2980b9; }
    .bg-red    { background: #c0392b; }
    .bg-yellow { background: #c9980a; }

    /* ===== INFO CARDS ===== */
    .info-card {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; height: 100%;
    }
    .card-head {
      padding: 9px 13px; background: #f7f9fb;
      border-bottom: 1px solid #d5dde5;
      display: flex; align-items: center; gap: 8px;
      font-size: 13.5px; font-weight: 700; color: #2c3e50;
    }
    .card-head i { color: #2980b9; font-size: 15px; }
    .card-body-inner { padding: 8px 13px; }
    .info-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 6px 0; border-bottom: 1px solid #eef2f5;
      font-size: 13px;
    }
    .info-row:last-child { border-bottom: none; }
    .info-row .val { color: #2980b9; font-weight: 600; cursor: pointer; }
    .info-row .val:hover { text-decoration: underline; }

    /* ===== BOTTOM CARDS ===== */
    .bottom-card {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; height: 100%;
    }
    .loading-text { color: #aaa; font-size: 13px; font-style: italic; padding: 6px 0; }

    /* ===== SETUP SECTION ===== */
    .setup-btn {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 16px; border-radius: 6px;
      font-size: 14px; font-weight: 600; color: #fff;
      text-decoration: none;
      transition: filter .15s, transform .1s;
      width: 100%;
    }
    .setup-btn:hover { filter: brightness(1.12); transform: translateY(-1px); color: #fff; text-decoration: none; }
    .setup-btn i { font-size: 22px; flex-shrink: 0; }
    .setup-btn-label { line-height: 1.3; }
    .setup-btn-label small { display: block; font-size: 11px; font-weight: 400; opacity: .88; }

    /* ===== PAGE HEADER ===== */
    .page-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 14px; padding-bottom: 10px;
      border-bottom: 2px solid #d5dde5;
    }
    .page-header h5 { margin: 0; font-size: 16px; font-weight: 700; color: #1a5276; }
    .page-header .btn { font-size: 13px; }

    /* ===== TABLE CHUNG ===== */
    .tbl-wrap {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; overflow: hidden;
    }
    .tbl-toolbar {
      padding: 10px 13px; background: #f7f9fb;
      border-bottom: 1px solid #d5dde5;
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .tbl-toolbar input, .tbl-toolbar select {
      border: 1px solid #cdd5dc; border-radius: 4px;
      padding: 5px 10px; font-size: 13px; outline: none;
    }
    .tbl-toolbar input:focus, .tbl-toolbar select:focus { border-color: #2980b9; }
    .tbl-toolbar .ms-auto { margin-left: auto; }
    table.main-tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
    table.main-tbl thead th {
      background: #eaf2fb; color: #1a5276;
      padding: 9px 12px; text-align: left;
      font-weight: 700; border-bottom: 2px solid #c8dff0;
      white-space: nowrap;
    }
    table.main-tbl tbody tr { border-bottom: 1px solid #eef2f5; }
    table.main-tbl tbody tr:last-child { border-bottom: none; }
    table.main-tbl tbody tr:hover { background: #f8fbff; }
    table.main-tbl td { padding: 8px 12px; vertical-align: middle; }
    .badge-status {
      display: inline-block; padding: 2px 9px;
      border-radius: 20px; font-size: 11.5px; font-weight: 600;
    }
    .badge-ok   { background: #d5f5e3; color: #1e8449; }
    .badge-warn { background: #fef9e7; color: #b7770d; }
    .badge-err  { background: #fadbd8; color: #922b21; }
    .badge-blue { background: #d6eaf8; color: #1a5276; }
    .tbl-action-btn {
      border: none; background: none; padding: 3px 7px;
      border-radius: 4px; cursor: pointer; font-size: 14px;
      transition: background .15s;
    }
    .tbl-action-btn:hover { background: #eaf2fb; }
    .tbl-foot {
      padding: 8px 13px; background: #f7f9fb;
      border-top: 1px solid #d5dde5;
      display: flex; align-items: center; justify-content: space-between;
      font-size: 12.5px; color: #555;
    }
    .tbl-foot .pagination { margin: 0; }
    .pagination .page-link { font-size: 12.5px; padding: 4px 9px; color: #2471a3; }
    .pagination .page-item.active .page-link { background: #2471a3; border-color: #2471a3; }

    /* ===== TẠO ĐƠN HÀNG ===== */
    .don-layout { display: flex; gap: 14px; align-items: flex-start; }
    .don-left  { flex: 1; min-width: 0; }
    .don-right { width: 320px; flex-shrink: 0; }
    .don-card  {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; margin-bottom: 12px; overflow: hidden;
    }
    .don-card .don-card-head {
      padding: 9px 13px; background: #f7f9fb;
      border-bottom: 1px solid #d5dde5;
      font-size: 13.5px; font-weight: 700; color: #2c3e50;
      display: flex; align-items: center; gap: 7px;
    }
    .don-card .don-card-body { padding: 12px 13px; }
    .don-card label { font-size: 12.5px; font-weight: 600; color: #555; margin-bottom: 3px; display: block; }
    .don-card input, .don-card select, .don-card textarea {
      width: 100%; border: 1px solid #cdd5dc; border-radius: 4px;
      padding: 6px 10px; font-size: 13px; outline: none;
    }
    .don-card input:focus, .don-card select:focus { border-color: #2471a3; }
    .sp-search-row {
      display: flex; gap: 8px; margin-bottom: 10px;
    }
    .sp-search-row input { flex: 1; }
    .gio-hang-item {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 0; border-bottom: 1px solid #eef2f5;
      font-size: 13px;
    }
    .gio-hang-item:last-child { border-bottom: none; }
    .gio-hang-item .sp-name { flex: 1; font-weight: 600; }
    .gio-hang-item .sp-qty {
      width: 52px; border: 1px solid #cdd5dc; border-radius: 4px;
      padding: 3px 6px; text-align: center; font-size: 13px; outline: none;
    }
    .gio-hang-item .sp-price { width: 90px; text-align: right; color: #c0392b; font-weight: 600; }
    .gio-hang-item .rm-btn {
      border: none; background: none; color: #e74c3c;
      cursor: pointer; font-size: 15px; padding: 0 3px;
    }
    .total-row {
      display: flex; justify-content: space-between;
      padding: 6px 0; font-size: 13px; border-bottom: 1px solid #eef2f5;
    }
    .total-row:last-child { border-bottom: none; font-weight: 700; font-size: 14px; color: #c0392b; }

    /* ===== DOANH SỐ CHART ===== */
    .chart-card {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; overflow: hidden; margin-bottom: 14px;
    }
    .chart-card .chart-head {
      padding: 9px 14px; background: #f7f9fb;
      border-bottom: 1px solid #d5dde5;
      font-size: 13.5px; font-weight: 700; color: #2c3e50;
      display: flex; align-items: center; justify-content: space-between; gap: 8px;
    }
    .chart-card .chart-body { padding: 14px; }
    .ds-stat {
      background: #fff; border: 1px solid #d5dde5;
      border-radius: 5px; padding: 13px 16px;
      display: flex; align-items: center; gap: 12px;
    }
    .ds-stat .ds-icon { font-size: 26px; opacity: .8; }
    .ds-stat .ds-label { font-size: 12px; color: #666; }
    .ds-stat .ds-val { font-size: 20px; font-weight: 700; color: #1a5276; }
  </style>
</head>
<body>

<!-- TOPBAR -->
<div id="topbar">
  <span class="topbar-brand"><i class="bi bi-shop-window me-2"></i>Quản Lý Bán Hàng</span>
  <div class="topbar-right">
    <span class="topbar-label">Cửa hàng</span>
    <select class="topbar-select">
      <option>Cửa hàng số 1</option>
      <option>Cửa hàng số 2</option>
    </select>
    <div class="dropdown">
      <span class="topbar-btn" data-bs-toggle="dropdown">
        Xin chào, admin <i class="bi bi-chevron-down ms-1" style="font-size:10px;"></i>
      </span>
      <ul class="dropdown-menu dropdown-menu-end mt-1">
        <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
        <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
      </ul>
    </div>
  </div>
</div>

<!-- SIDEBAR -->
<div id="sidebar">
  
  <a href="#" class="nav-item" onclick="return showPage('trangchu', this)">
    <i class="bi bi-house-door"></i> Trang Chủ
  </a>
  <a href="#" class="nav-item" onclick="return showPage('taodon', this)">
    <i class="bi bi-plus-circle"></i> Tạo đơn hàng
  </a>
  
  <a href="#" class="nav-item" onclick="return showPage('khachhang', this)">
    <i class="bi bi-people"></i> Khách hàng
  </a>
        <a href="#" class="nav-item" onclick="return showPage('Admin_Staff', this)">
            <i class="bi bi-person-gear"></i> Admin/Staff
        </a>
  <a href="#" class="nav-item" onclick="return showPage('nhapkho', this)">
    <i class="bi bi-arrow-bar-down"></i> Nhập kho
  </a>
  <a href="#" class="nav-item" onclick="return showPage('tonkho', this)">
    <i class="bi bi-archive"></i> Tồn kho
  </a>
  <a href="#" class="nav-item" onclick="return showPage('doanhthu', this)">
    <i class="bi bi-bar-chart-line"></i> Doanh số
  </a>
  
  <a href="#" class="nav-item" onclick="return showPage('loinhuan', this)">
    <i class="bi bi-currency-dollar"></i> Lợi nhuận
  </a>
  <a href="#" class="nav-item" onclick="return showPage('thietlap', this)">
    <i class="bi bi-gear"></i> Thiết lập
  </a>
</div>

<!-- MAIN -->
<div id="main">

  <!-- ====== TRANG CHỦ ====== -->
  <div class="page-section active" id="page-trangchu">

    <div class="today-header">
      <span class="badge-today">
        <i class="bi bi-check2-square text-primary"></i> Hoạt động hôm nay
      </span>
    </div>

    <!-- Stat Cards -->
    <div class="row g-2 mb-3">
      <div class="col-md-3 col-sm-6">
        <div class="stat-card bg-green">
          <i class="bi bi-credit-card stat-icon"></i>
          <div>
            <div class="stat-label">Tiền bán hàng</div>
            <div class="stat-value">0</div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card bg-blue">
          <i class="bi bi-cart3 stat-icon"></i>
          <div>
            <div class="stat-sub">Số đơn hàng: 0</div>
            <div class="stat-sub">Số sản phẩm: 0</div>
            <div class="stat-value">0</div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card bg-red">
          <i class="bi bi-arrow-counterclockwise stat-icon"></i>
          <div>
            <div class="stat-label">Hàng khách trả</div>
            <div class="stat-value">0</div>
          </div>
        </div>
      </div>
      <div class="col-md-3 col-sm-6">
        <div class="stat-card bg-yellow">
          <i class="bi bi-cloud stat-icon"></i>
          <div>
            <div class="stat-label">Đơn hàng web</div>
            <div class="stat-value">0</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Info Cards -->
    <div class="row g-2 mb-3">
      <div class="col-md-4">
        <div class="info-card">
          <div class="card-head"><i class="bi bi-play-circle-fill"></i> Hoạt động</div>
          <div class="card-body-inner">
            <div class="info-row"><span>Tiền bán hàng</span><span class="val">0</span></div>
            <div class="info-row"><span>Số đơn hàng</span><span class="val">0</span></div>
            <div class="info-row"><span>Số sản phẩm</span><span class="val">0</span></div>
            <div class="info-row"><span>Khách hàng trả</span><span class="val">0</span></div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="info-card">
          <div class="card-head"><i class="bi bi-arrow-repeat"></i> Thông tin kho</div>
          <div class="card-body-inner">
            <div class="info-row"><span>Tồn kho</span><span class="val">6</span></div>
            <div class="info-row"><span>Hết Hàng</span><span class="val">0</span></div>
            <div class="info-row"><span>Sắp hết hàng</span><span class="val">0</span></div>
            <div class="info-row"><span>Vượt định mức</span><span class="val">0</span></div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="info-card">
          <div class="card-head"><i class="bi bi-grid-3x3-gap-fill"></i> Thông tin sản phẩm</div>
          <div class="card-body-inner">
            <div class="info-row"><span>Sản phẩm/Nhà sản xuất</span><span class="val">6 / 36</span></div>
            <div class="info-row"><span>Chưa làm giá bán</span><span class="val">0</span></div>
            <div class="info-row"><span>Chưa nhập giá mua</span><span class="val">0</span></div>
            <div class="info-row"><span>Hàng chưa phân loại</span><span class="val">0</span></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Cards -->
    <div class="row g-2">
      <div class="col-md-4">
        <div class="bottom-card">
          <div class="card-head"><i class="bi bi-bar-chart-line"></i> Biểu đồ doanh số tuần</div>
          <div class="card-body-inner">
            <canvas id="chartDoanhSo" height="160"></canvas>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="bottom-card">
          <div class="card-head"><i class="bi bi-globe"></i> Thông tin từ web</div>
          <div class="card-body-inner">
            <div class="info-row"><span>Đơn hàng web mới</span><span class="val">0</span></div>
            <div class="info-row"><span>Khách đăng ký mới</span><span class="val">0</span></div>
            <div class="info-row"><span>Bình luận chờ duyệt</span><span class="val">0</span></div>
            <div class="info-row"><span>Lượt truy cập hôm nay</span><span class="val">0</span></div>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="bottom-card">
          <div class="card-head"><i class="bi bi-rss"></i> Tin chuyên ngành</div>
          <div class="card-body-inner">
            <p class="loading-text">Loading ...</p>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /trangchu -->

  <!-- ====== TẠO ĐƠN HÀNG ====== -->
  <div class="page-section" id="page-taodon">
    <div class="page-header">
      <h5><i class="bi bi-plus-circle me-2"></i>Tạo đơn hàng</h5>
      <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-clock-history me-1"></i>Đơn nháp</button>
        <button class="btn btn-success btn-sm" onclick="xuLyDon()"><i class="bi bi-check2 me-1"></i>Xác nhận đơn</button>
      </div>
    </div>

    <div class="don-layout">
      <!-- LEFT: Chọn sản phẩm -->
      <div class="don-left">

        <div class="don-card">
          <div class="don-card-head"><i class="bi bi-search text-primary"></i> Tìm sản phẩm</div>
          <div class="don-card-body">
            <div class="sp-search-row">
              <input type="text" id="spSearchInput" placeholder="Tìm theo tên, mã vạch, SKU..." oninput="filterSanPham()">
              <select id="spDanhMuc" onchange="filterSanPham()" style="width:160px;">
                <option value="">Tất cả danh mục</option>
                <option>Điện thoại</option>
                <option>Phụ kiện</option>
                <option>Laptop</option>
              </select>
            </div>
            <div style="max-height:280px; overflow-y:auto;">
              <table class="main-tbl" id="spTable">
                <thead><tr>
                  <th>Mã SP</th><th>Tên sản phẩm</th><th>Tồn</th><th>Giá bán</th><th></th>
                </tr></thead>
                <tbody id="spTbody">
                  <tr data-ten="iPhone 14"><td>SP001</td><td>iPhone 14</td><td>12</td><td>19,990,000đ</td><td><button class="btn btn-primary btn-sm" onclick="themVaoGio('SP001','iPhone 14',19990000)"><i class="bi bi-plus"></i></button></td></tr>
                  <tr data-ten="Samsung S23"><td>SP002</td><td>Samsung S23</td><td>8</td><td>14,500,000đ</td><td><button class="btn btn-primary btn-sm" onclick="themVaoGio('SP002','Samsung S23',14500000)"><i class="bi bi-plus"></i></button></td></tr>
