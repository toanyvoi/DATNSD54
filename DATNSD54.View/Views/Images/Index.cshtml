@model IEnumerable<DATNSD54.DAO.Models.Image>

@{
    ViewData["Title"] = "Thư viện hình ảnh";
}

@section Styles {
    <style>
        .admin-gallery-page {
            background: #f8f9fa;
            min-height: 100vh;
            padding: 30px 0;
        }

        .gallery-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Header & Search Area */
        .gallery-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .gallery-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #2c3e50;
            margin: 0;
        }

        .btn-add-image {
            background: #2c3e50;
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
        }

        .btn-add-image:hover {
            background: #1a252f;
            color: white;
            transform: translateY(-2px);
        }

        /* Grid System */
        .image-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .image-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            position: relative;
            border: 1px solid #edf2f7;
        }

        .image-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.12);
        }

        /* Thumbnail container */
        .img-wrapper {
            position: relative;
            height: 200px;
            background: #f1f4f8;
            overflow: hidden;
        }

        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }

        .image-card:hover .img-wrapper img {
            transform: scale(1.1);
        }

        /* Status Badge Over Image */
        .status-tag {
            position: absolute;
            top: 12px;
            right: 12px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            z-index: 2;
        }

        .status-visible { background: #def7ec; color: #03543f; }
        .status-hidden { background: #fde8e8; color: #9b1c1c; }

        /* Card Content */
        .card-info {
            padding: 15px;
        }

        .product-name {
            font-weight: 700;
            color: #2d3748;
            font-size: 1rem;
            margin-bottom: 5px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .date-info {
            font-size: 0.8rem;
            color: #a0aec0;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Hover Overlay Actions */
        .card-actions {
            display: flex;
            padding: 12px 15px;
            border-top: 1px solid #f7fafc;
            gap: 10px;
            background: #fdfdfd;
        }

        .btn-tool {
            flex: 1;
            text-align: center;
            padding: 8px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

        .tool-edit { background: #f0f7ff; color: #007bff; }
        .tool-details { background: #f8f9fa; color: #6c757d; }
        .tool-delete { background: #fff5f5; color: #e74c3c; }

        .tool-edit:hover { background: #007bff; color: white; }
        .tool-details:hover { background: #6c757d; color: white; }
        .tool-delete:hover { background: #e74c3c; color: white; }

    </style>
}

<div class="admin-gallery-page">
    <div class="gallery-container">
        
        <header class="gallery-header">
            <div>
                <h2 class="gallery-title">Thư viện Ảnh Sản phẩm</h2>
                <span class="text-muted small">Tổng số: @Model.Count() hình ảnh</span>
            </div>
            <a asp-action="Create" class="btn-add-image">
                <i class="fas fa-plus-circle mr-2"></i> Thêm ảnh mới
            </a>
        </header>

        <div class="image-grid">
            @foreach (var item in Model)
            {
                <div class="image-card">
                    <span class="status-tag @(item.Trang_Thai ? "status-visible" : "status-hidden")">
                        @(item.Trang_Thai ? "Hiển thị" : "Đang ẩn")
                    </span>

                    <div class="img-wrapper">
                        <img src="@item.IMG" alt="Product Image" onerror="this.src='/images/no-image.png'" />
                    </div>

                    <div class="card-info">
                        <div class="product-name" title="@item.Product.Ten">
                            <i class="fas fa-box-open mr-1 text-muted"></i> @item.Product.Ten
                        </div>
                        <div class="date-info">
                            <i class="far fa-calendar-alt"></i> @item.Ngay_Tao.ToString("dd/MM/yyyy")
                        </div>
                    </div>

                    <div class="card-actions">
                        <a asp-action="Edit" asp-route-id="@item.ID" class="btn-tool tool-edit" title="Chỉnh sửa">
                            <i class="fas fa-pen"></i>
                        </a>
                        <a asp-action="Details" asp-route-id="@item.ID" class="btn-tool tool-details" title="Chi tiết">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.ID" class="btn-tool tool-delete" title="Xóa">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>