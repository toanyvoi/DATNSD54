@model DATNSD54.DAO.Models.Image

@{
    ViewData["Title"] = "Chi tiết hình ảnh";
}

@section Styles {
    <style>
        .admin-details-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 60px 0;
        }

        .details-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .details-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            display: flex;
            flex-direction: row;
        }

        /* Phía bên trái: Hiển thị ảnh */
        .image-viewer {
            flex: 1;
            background: #2c3e50;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            min-height: 450px;
        }

        .main-img {
            max-width: 100%;
            max-height: 400px;
            border-radius: 8px;
            box-shadow: 0 5px 25px rgba(0,0,0,0.3);
            object-fit: contain;
        }

        /* Phía bên phải: Thông tin */
        .details-content {
            flex: 1;
            padding: 40px;
            display: flex;
            flex-direction: column;
        }

        .details-header {
            margin-bottom: 30px;
        }

        .details-header h2 {
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 5px;
        }

        .info-group {
            margin-bottom: 25px;
        }

        .info-label {
            display: block;
            color: #95a5a6;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
        }

        .info-value {
            color: #34495e;
            font-size: 1.05rem;
            font-weight: 500;
        }

        .url-box {
            background: #f8f9fa;
            padding: 10px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 0.9rem;
            word-break: break-all;
            border: 1px solid #eef0f2;
        }

        .footer-actions {
            margin-top: auto;
            padding-top: 30px;
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .btn-edit-main {
            background: #2c3e50;
            color: white;
            padding: 12px 25px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s;
            flex: 1;
            text-align: center;
        }

        .btn-edit-main:hover {
            background: #1a252f;
            color: white;
            transform: translateY(-2px);
        }

        .btn-back-link {
            color: #7f8c8d;
            text-decoration: none;
            font-weight: 500;
        }

        /* Responsive cho Mobile */
        @@media (max-width: 768px) {
            .details-card { flex-direction: column; }
            .image-viewer { min-height: 300px; }
        }
    </style>
}

<div class="admin-details-page">
    <div class="details-container">
        <div class="details-card">
            <div class="image-viewer">
                <img src="@Model.IMG" class="main-img" alt="Product Image" onerror="this.src='/images/no-image.png'" />
            </div>

            <div class="details-content">
                <div class="details-header">
                    <h2>Chi tiết hình ảnh</h2>
                    <p class="text-muted">ID bản ghi: #@Model.ID</p>
                </div>

                <div class="info-group">
                    <span class="info-label">Sản phẩm liên kết</span>
                    <span class="info-value text-primary" style="font-size: 1.2rem;">
                        <i class="fas fa-box mr-2"></i>@Model.Product.Ten
                    </span>
                </div>

                <div class="info-group">
                    <span class="info-label">Đường dẫn ảnh (URL)</span>
                    <div class="url-box">@Model.IMG</div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="info-group">
                            <span class="info-label">Ngày tạo</span>
                            <span class="info-value">@Model.Ngay_Tao.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="info-group">
                            <span class="info-label">Trạng thái</span>
                            <span class="info-value">
                                @if (Model.Trang_Thai)
                                {
                                    <span class="badge badge-success">Đang hiển thị</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Đang ẩn</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>

                <div class="footer-actions">
                    <a asp-action="Index" class="btn-back-link">
                        <i class="fas fa-arrow-left mr-1"></i> Quay lại
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model?.ID" class="btn-edit-main">
                        <i class="fas fa-edit mr-1"></i> Chỉnh sửa ảnh
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>