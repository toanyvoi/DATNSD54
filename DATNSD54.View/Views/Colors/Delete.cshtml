@model DATNSD54.DAO.Models.Color

@{
    ViewData["Title"] = "Xóa màu sắc";
}

@section Styles {
    <style>
        .admin-delete-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 60px 0;
        }

        .delete-container {
            max-width: 600px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .delete-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
            text-align: center;
        }

        .delete-icon {
            width: 80px;
            height: 80px;
            background: #fff5f5;
            color: #e74c3c;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 35px;
            border: 2px solid #feb2b2;
        }

        .delete-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .delete-subtitle {
            color: #718096;
            margin-bottom: 30px;
        }

        /* Detail List Styling */
        .info-box {
            background: #fdfdfd;
            border: 1px solid #edf2f7;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: left;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px dashed #edf2f7;
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 600;
            color: #4a5568;
        }

        .info-value {
            color: #2d3748;
            font-weight: 500;
        }

        /* Buttons */
        .btn-group-custom {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .btn-confirm-delete {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 14px;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
            width: 100%;
        }

        .btn-confirm-delete:hover {
            background: #c0392b;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3);
        }

        .btn-cancel {
            background: #f8f9fa;
            color: #718096;
            padding: 12px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-cancel:hover {
            background: #edf2f7;
            color: #2d3748;
        }
    </style>
}

<div class="admin-delete-page">
    <div class="delete-container">
        <div class="delete-card">
            <div class="delete-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            
            <h2 class="delete-title">Xác nhận xóa?</h2>
            <p class="delete-subtitle">Hành động này không thể hoàn tác. Bạn có chắc chắn muốn xóa màu sắc này?</p>

            <div class="info-box">
                <div class="info-row">
                    <span class="info-label">@Html.DisplayNameFor(model => model.Ma)</span>
                    <span class="info-value"><code>@Html.DisplayFor(model => model.Ma)</code></span>
                </div>
                <div class="info-row">
                    <span class="info-label">@Html.DisplayNameFor(model => model.Ten)</span>
                    <span class="info-value">@Html.DisplayFor(model => model.Ten)</span>
                </div>
                <div class="info-row">
                    <span class="info-label">@Html.DisplayNameFor(model => model.Ngay_Tao)</span>
                    <span class="info-value">@Model.Ngay_Tao.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <form asp-action="Delete" class="btn-group-custom">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-confirm-delete">
                    <i class="fas fa-trash-alt mr-2"></i> Có, Xác nhận xóa
                </button>
                <a asp-action="Index" class="btn-cancel">Hủy bỏ và Quay lại</a>
            </form>
        </div>
    </div>
</div>