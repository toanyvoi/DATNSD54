@model DATNSD54.DAO.Models.Voucher

@{
    ViewData["Title"] = "Chỉnh sửa Voucher";
}

@section Styles {
    <style>
        .admin-edit-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 40px 0;
        }

        .edit-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            padding: 40px;
            max-width: 850px;
            margin: 0 auto;
            border: 1px solid #eef2f7;
        }

        .edit-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .form-label {
            font-weight: 700;
            color: #4a5568;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 10px;
            display: block;
        }

        .form-control, .form-select {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 12px 18px;
            transition: all 0.3s;
            background-color: #f8fbff;
            height: auto;
        }

            .form-control:focus {
                border-color: #4299e1;
                box-shadow: 0 0 0 3px rgba(66, 153, 225, 0.15);
                background-color: white;
                outline: none;
            }

        /* Style cho trường ID bị khóa */
        .readonly-id {
            background-color: #edf2f7 !important;
            border: 1px dashed #cbd5e0 !important;
            color: #718096 !important;
            font-family: 'Courier New', Courier, monospace;
            font-weight: 700;
            letter-spacing: 1px;
        }

        .btn-update {
            background: #2d3748;
            color: white;
            padding: 14px 40px;
            border-radius: 12px;
            font-weight: 700;
            border: none;
            transition: 0.3s;
            cursor: pointer;
        }

            .btn-update:hover {
                background: #1a202c;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .btn-back {
            color: #a0aec0;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

            .btn-back:hover {
                color: #2d3748;
            }

        .input-group-text {
            border-radius: 0 12px 12px 0;
            background: #f8fbff;
            border: 1px solid #e2e8f0;
            border-left: none;
        }
    </style>
}

<div class="admin-edit-page">
    <div class="container">
        <div class="edit-card">
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-long-arrow-alt-left"></i> Quay lại danh sách
            </a>

            <h2 class="edit-title">
                <i class="fas fa-pen-square text-warning"></i> Cập nhật thông tin Voucher
            </h2>

            <form asp-action="Edit" method="post" id="editVoucherForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small" style="border-radius: 12px;"></div>

                @* ID gửi ngầm về server *@
                <input type="hidden" asp-for="ID" />

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Mã định danh (Cố định)</label>
                        <input asp-for="ID" class="form-control readonly-id" readonly />
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label">Tên Chương Trình</label>
                        <input asp-for="Ten" class="form-control" placeholder="Nhập tên mới..." required />
                        <span asp-validation-for="Ten" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-4">
                        <label class="form-label">Tỷ lệ giảm (%)</label>
                        <div class="input-group">
                            <input asp-for="Ty_Le_Giam" class="form-control" type="number" min="0" max="100" step="0.01" required />
                            <div class="input-group-append"><span class="input-group-text">%</span></div>
                        </div>
                        <span asp-validation-for="Ty_Le_Giam" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-4">
                        <label class="form-label">Số lượng còn lại</label>
                        <input asp-for="So_Luong" class="form-control" type="number" min="0" required />
                        <span asp-validation-for="So_Luong" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-4">
                        <label class="form-label">Giới Hạn sử dụng trên từng tk</label>
                        <input asp-for="Gioi_Han_Su_Dung" class="form-control" type="number" min="0" required />
                        <span asp-validation-for="Gioi_Han_Su_Dung" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-4">
                        <label class="form-label">Trạng thái hiện tại</label>
                        <select asp-for="Trang_Thai" class="form-select w-100">
                            <option value="1">Đang hoạt động</option>
                            <option value="0">Tạm khóa/Hết hàng</option>
                        </select>
                        <span asp-validation-for="Trang_Thai" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Đơn tối thiểu (VNĐ)</label>
                        <input asp-for="Don_Hang_Toi_Thieu" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Don_Hang_Toi_Thieu" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label">Giảm tối đa (VNĐ)</label>
                        <input asp-for="Giam_Toi_Da" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Giam_Toi_Da" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">Ngày bắt đầu hiệu lực</label>
                        <input asp-for="Ngay_Bat_Dau" class="form-control" type="datetime-local"
                               id="Ngay_Bat_Dau"
                               value="@Model.Ngay_Bat_Dau.ToString("yyyy-MM-ddTHH:mm")" required />
                        <span asp-validation-for="Ngay_Bat_Dau" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label class="form-label">Ngày kết thúc</label>
                        <input asp-for="Ngay_Ket_Thuc" class="form-control" type="datetime-local"
                               id="Ngay_Ket_Thuc"
                               value="@Model.Ngay_Ket_Thuc.ToString("yyyy-MM-ddTHH:mm")" required />
                        <span asp-validation-for="Ngay_Ket_Thuc" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end">
                    <button type="submit" class="btn-update">
                        <i class="fas fa-sync-alt mr-2"></i> LƯU THAY ĐỔI
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const startInput = document.getElementById('Ngay_Bat_Dau');
            const endInput = document.getElementById('Ngay_Ket_Thuc');

            // Logic kiểm tra ngày tháng nhanh trên Client
            startInput.addEventListener('change', function() {
                endInput.min = startInput.value;
            });

            document.getElementById('editVoucherForm').addEventListener('submit', function(e) {
                if (new Date(endInput.value) < new Date(startInput.value)) {
                    e.preventDefault();
                    alert("Lỗi: Ngày kết thúc không thể diễn ra trước ngày bắt đầu!");
                }
            });
        });
    </script>
}