@model IEnumerable<DATNSD54.DAO.DTO.ProductDisplayDTO>

<div class="admin-index-page">
    <div class="index-card shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-1">Danh sách Sản phẩm</h2>
                <p class="text-muted small">Hiển thị chi tiết trạng thái và đối tác</p>
            </div>
            <a asp-action="Create" class="btn btn-dark btn-lg shadow-sm" style="border-radius: 12px;">
                <i class="fas fa-plus-circle me-2"></i> Thêm mới
            </a>
        </div>

        <div class="table-responsive">
            <table class="table custom-table align-middle">
                <thead>
                    <tr>
                        <th>Hình ảnh</th>
                        <th>Tên & Loại</th>
                        <th>Nhà cung cấp / Brand</th>
                        <th>Giá bán từ</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.URLImage) ? "/images/no-image.png" : item.URLImage)"
                                     class="rounded-3 shadow-sm" style="width: 50px; height: 50px; object-fit: cover;">
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Name</div>
                                <div class="small text-muted">@item.ProductTypeName</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark small">@item.SupplierName</div>
                                <div class="badge bg-light text-dark border">@item.brandName</div>
                            </td>
                            <td>
                                <span class="fw-bold text-danger">@item.MinPrice.ToString("N0") ₫</span>
                                @if (item.Sale > 0)
                                {
                                    <span class="badge bg-danger-soft text-danger ms-1">-@item.Sale%</span>
                                }
                            </td>
                            <td>
                                <span class="status-badge @(item.trangThai == "Đang bán" ? "status-active" : "status-danger")">
                                    @item.trangThai
                                </span>
                            </td>
                            <td>
                                <div class="action-links d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-action btn-details"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>