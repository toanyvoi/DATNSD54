@model DATNSD54.DAO.DTO.ProductDTO
@{
    int dem = 1;
}

@section Styles {
    <link rel="stylesheet" href="~/css/productdetail.css" asp-append-version="true" />

    <style>
        .thumb-scroll-container {
            /* 1. Giới hạn chiều cao tương đương khoảng 3 cái ảnh */
            max-height: 280px;
            /* 2. Bật tính năng cuộn theo chiều dọc */
            overflow-y: auto;
            /* 3. Ẩn thanh cuộn xấu xí của trình duyệt đi cho đẹp (Tùy chọn) */
            scrollbar-width: none; /* Cho Firefox */
        }

            .thumb-scroll-container::-webkit-scrollbar {
                display: none; /* Cho Chrome, Safari, Edge */
            }

        .img-item {
            margin-bottom: 10px; /* Khoảng cách giữa các ảnh nhỏ */
            list-style: none;
        }

        

        .img-wrapper {
            position: relative;
            display: inline-block;
            overflow: hidden; /* Cắt góc thừa nếu ảnh có bo tròn */
           
        }
        /* 2. Lớp phủ chữ Xóa: Mặc định sẽ ẩn đi (opacity = 0) và phủ kín cái ảnh */
        .delete-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(219, 68, 85, 0.8); /* Màu đỏ mờ (chuẩn màu xóa lỗi) */
            color: white !important; /* Chữ màu trắng */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: bold;
            text-decoration: none;
            opacity: 0; /* ẩn di khi chưa kích hoạt lúc bình thường */
            transition: opacity 0.3s ease; /* Tạo hiệu ứng mượt mà khi hiện lên */
            cursor: pointer;
        }

            /* Thêm hiệu ứng icon rác to nhẹ một chút cho đẹp */
            .delete-overlay i {
                font-size: 18px;
                margin-bottom: 2px;
            }

        /* Khi người dùng HOVER vào img-wrapper thì hiện chữ Xóa lên */
        .img-wrapper:hover .delete-overlay {
            opacity: 1; /* Hiện hình lên */
        }

        /* ảnh zoom nhẹ khi hover */
        .img-wrapper:hover .small-img {
            transform: scale(1.05);
        }
    </style>
}
<div class="admin-edit-page">
    <div class="edit-card shadow-sm">
        <div class="row g-5">
            <div class="col-lg-5 col-12 daonguoc">
                <div class="img-product">
                    <ul class="all-img thumb-scroll-container p-0 m-0">
                        @if (Model.ListIMG != null && Model.ListIMG.Any())
                        {
                            @* Nếu có ảnh thì mới chạy vòng lặp *@
                            @foreach (var imgObj in Model.ListIMG)
                            {
                                <li class="img-item">
                                    <div class="img-wrapper">
                                        <img src="@Url.Content(imgObj)"
                                             class="small-img"
                                             alt="anh @dem"
                                             onclick="changeImg(@dem)"
                                             id="thumb-@dem">

                                        <a href="javascript:void(0);"
                                           class="delete-overlay"
                                           onclick="if(confirm('Bạn có chắc muốn xóa ảnh này không?')) { document.getElementById('form-delete-@dem').submit(); }">
                                            <i class="fas fa-trash-alt"></i> Xóa
                                        </a>
                                    </div>
                                    <form id="form-delete-@dem"
                                          asp-action="Delete"
                                          asp-controller="Images"
                                          method="post"
                                          style="display:none;">
                                        <input type="hidden" name="Url" value="@imgObj" />
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                    </form>
                                </li>
                                dem++;
                            }
                        }
                        else
                        {
                            @* Nếu không có ảnh nào thì hiện 1 cái ảnh mặc định cho đẹp đội hình *@
                            <li class="img-item">
                                <img src="/images/no-image.png" class="small-img" alt="no-image">
                            </li>
                        }

                    </ul>
                    <div class="col-2">
                        <button class="btn btn-primary text-nowrap" data-bs-toggle="modal" data-bs-target="#Modal-Images">
                            <i class="fas fa-plus me-1"></i> Thêm ảnh
                        </button>
                    </div>
                </div>
                <div id="" style="cursor: pointer; ">
                    @if (Model.ListIMG != null && Model.ListIMG.Any())
                    {
                        <img src="@Url.Content(Model.ListIMG[0])" style="width: 320px!important; height: 320px!important; object-fit: cover;" lass="big-img" alt="ảnh chính" id="img-main" xoriginal="./assets/img/product/ult1.jpg" >
                    }
                    else
                    {
                        @* Ảnh dự phòng nếu DB không có ảnh nào *@
                        <img src="~/img/product/no-image.jpg"
                             style="width: 320px!important; height: 320px!important; object-fit: cover;"
                             class="big-img"
                             alt="không có ảnh"
                             id="img-main">
                    }
                   
                </div>
            </div>
            <div class="col-lg-7 col-12">
                <div class="d-flex gap-2 mb-2">
                    <span class="badge bg-primary-soft text-primary " style="font-size: 13px;">Loại: @Model.type</span>
                    <span class="badge bg-secondary-soft text-secondary " style="font-size: 13px;">Brand: @Model.brand</span>
                </div>

                <h2 class="fw-bold text-dark">@Model.Ten</h2>
                <p class="text-muted mb-2 " style="font-size: 13px;">Mã SP: <b>@Model.Ma</b> | Năm sản xuất: <b>@Model.Nam_SX</b></p>
                <p class="text-muted mb-2 " style="font-size: 13px;">
                    Tổng Số Lượng: <b>@Model.quantity</b>
                </p>
                <div class="p-3 bg-light rounded-4 mt-3 mb-4 d-inline-block pe-5">
                    <span class="text-muted d-block fw-bold text-uppercase" style="font-size: 10px;">Giá bán thấp nhất</span>
                    <span class=" fw-bold text-danger" style="font-size: 11px;">@Model.salePriceMin?.ToString("N0") ₫</span>
                </div>

                <p style="white-space: pre-line;" class="text-secondary">@Model.Mo_Ta</p>
            </div>
        </div>

        <div class="mt-5 border-top pt-4">
            <h5 class="fw-bold mb-3">Danh sách biến thể</h5>
            <table class="table custom-table">
                <thead class="table-light">
                    <tr><th>Size</th><th>Màu sắc</th><th>Giá gốc</th><th>Giá Sale</th><th>Tồn kho</th></tr>
                </thead>
                <tbody>
                    @foreach (var v in Model.ListProductDetail)
                    {
                        <tr>
                            <td class="fw-bold">@v.Size</td>
                            <td>
                                <span style="background:@v.Color; width:15px; height:15px; display:inline-block; border-radius:50%; border:1px solid #ccc;"></span> @v.Color
                            </td>
                            <td class="text-muted text-decoration-line-through small">@v.Don_Gia.ToString("N0")</td>
                            <td class="fw-bold text-primary">@v.salePrice.ToString("N0") ₫</td>
                            <td>@v.SL</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-4 border-top pt-4 text-end">
            <a asp-action="Index" class="btn btn-light px-4" style="border-radius: 12px;">Quay Lại</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark px-4 ms-2" style="border-radius: 12px;">Sửa Thông Tin</a>
        </div>
    </div>
</div>

<div class="modal fade" id="Modal-Images" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold">Thêm hình ảnh</h5>
                    <small class="text-muted">Upload ảnh cho sản phẩm</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-action="Create"
                  asp-controller="Images"
                  method="post"
                  enctype="multipart/form-data">

                <div class="modal-body">
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <div class="form-group mb-3">
                        <label class="form-label fw-bold">Chọn ảnh từ máy tính</label>
                        <input type="file" name="fileImage" id="fileImage" class="form-control" onchange="previewImage(this)" />
                    </div>

                    <div class="image-preview-container border rounded d-flex flex-column align-items-center justify-content-center p-4 bg-light" style="min-height: 200px;">
                        <img id="imgPreview" class="img-fluid rounded d-none" style="max-height: 180px;" />

                        <div id="preview-placeholder" class="text-center text-muted">
                            <i class="fas fa-image fa-3x mb-2"></i>
                            <p class="mb-0 text-sm">Chưa có ảnh nào được chọn</p>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-plus-circle me-1"></i> Thêm ảnh ngay
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>
@section Scripts {
    <script>
        function previewImage(input) {
            var preview = document.getElementById('imgPreview');
            var placeholder = document.getElementById('preview-placeholder');

            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none'); // Hiện ảnh
                    placeholder.classList.add('d-none'); // Ẩn chữ placeholder
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                preview.src = "";
                preview.classList.add('d-none');
                placeholder.classList.remove('d-none');
            }
        }
    </script>
}