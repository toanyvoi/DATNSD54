@model DATNSD54.DAO.Models.Address

<div class="container mt-4">
    <h4>Thêm địa chỉ mới</h4>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label class="control-label">Họ tên người nhận</label>
                    <input asp-for="HoTen" class="form-control" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Số điện thoại</label>
                    <input asp-for="SDT" class="form-control" />
                    <span asp-validation-for="SDT" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label">Địa chỉ chi tiết</label>
                    <textarea asp-for="DiaChiChitiet" class="form-control"></textarea>
                    <span asp-validation-for="DiaChiChitiet" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Lưu lại</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </form>
        </div>
    </div>
</div>