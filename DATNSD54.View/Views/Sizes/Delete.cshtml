@model DATNSD54.DAO.Models.Size

@{
    ViewData["Title"] = "Xóa Size";
}

@section Styles {
    <style>
        .admin-delete-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 60px 0;
        }

        .delete-container {
            max-width: 700px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .delete-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
            border-top: 5px solid #e74c3c;
        }

        .delete-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .warning-icon {
            width: 70px;
            height: 70px;
            background: #fdf2f2;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .warning-icon i {
            font-size: 30px;
            color: #e74c3c;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            background: #f8f9fa;
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .info-item {
            border-bottom: 1px solid #edf2f7;
            padding: 10px 0;
        }

        .info-item.full-width {
            grid-column: span 2;
        }

        .info-label {
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: #95a5a6;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .info-value {
            font-weight: 600;
            color: #2c3e50;
        }

        .btn-delete-confirm {
            background: #e74c3c;
            border: none;
            color: white;
            padding: 14px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
            font-size: 1.1rem;
        }

        .btn-delete-confirm:hover {
            background: #c0392b;
            transform: translateY(-2px);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #95a5a6;
            text-decoration: none;
        }

        .back-link:hover {
            color: #2c3e50;
        }
    </style>
}

<div class="admin-delete-page">
    <div class="delete-container">
        <div class="delete-card">
            <div class="delete-header">
                <div class="warning-icon">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <h2 class="font-weight-bold">Xác nhận xóa?</h2>
                <p class="text-muted">Dữ liệu này sẽ mất vĩnh viễn và không thể phục hồi.</p>
            </div>

            <div class="info-grid">
                <div class="info-item full-width">
                    <span class="info-label">Mã Size</span>
                    <span class="info-value">@Html.DisplayFor(model => model.Ma)</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Tên Size</span>
                    <span class="info-value">@Html.DisplayFor(model => model.Ten)</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Ngày tạo</span>
                    <span class="info-value">@Model.Ngay_Tao.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-delete-confirm">
                    <i class="fas fa-trash-alt mr-2"></i> Xác nhận xóa ngay
                </button>
            </form>

            <a asp-action="Index" class="back-link">Hủy và quay lại</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $('.btn-delete-confirm').click(function () {
            return confirm("Bạn có chắc chắn muốn thực hiện hành động này không?");
        });
    </script>
}