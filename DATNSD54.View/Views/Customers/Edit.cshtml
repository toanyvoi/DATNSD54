@model DATNSD54.DAO.Models.Customer

@{
    ViewData["Title"] = "Chỉnh sửa khách hàng";
}

@section Styles {
    <style>
        .admin-form-page {
            background: #f8f9fa;
            min-height: calc(100vh - 200px);
            padding: 40px 0;
        }

        .form-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .form-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            padding: 40px;
        }

        .form-header {
            text-align: center;
            margin-bottom: 35px;
            position: relative;
        }

        .header-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #3f51b5 0%, #2196f3 100%);
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 20px rgba(63, 81, 181, 0.2);
            color: white;
            font-size: 30px;
        }

        .edit-avatar-preview {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            position: absolute;
            right: 0;
            top: 0;
        }

        .form-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #2c3e50;
        }

        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, #e8ecef, transparent);
            margin: 25px 0;
        }

        .control-label {
            font-weight: 600;
            color: #34495e;
            margin-bottom: 8px;
            display: block;
        }

        .form-control {
            border-radius: 10px;
            padding: 10px 15px;
            border: 2px solid #e8ecef;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #3f51b5;
            box-shadow: 0 0 0 0.2rem rgba(63, 81, 181, 0.1);
            outline: none;
        }

        .btn-submit {
            background: #3f51b5;
            border: none;
            color: white;
            padding: 14px 30px;
            border-radius: 12px;
            font-weight: 600;
            width: 100%;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .btn-submit:hover {
            background: #303f9f;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(63, 81, 181, 0.3);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 25px;
            color: #7f8c8d;
            text-decoration: none;
            font-weight: 500;
        }

        .back-link:hover {
            color: #2c3e50;
        }
        
        .custom-switch .custom-control-label::before {
            height: 1.5rem;
            width: 2.75rem;
            border-radius: 1rem;
        }
        
        .custom-switch .custom-control-label::after {
            width: calc(1.5rem - 4px);
            height: calc(1.5rem - 4px);
            border-radius: 1rem;
        }
    </style>
}

<div class="admin-form-page">
    <div class="form-container">
        <div class="form-card">
            <div class="form-header">
                <div class="header-icon">
                    <i class="fas fa-user-edit"></i>
                </div>
                @if(!string.IsNullOrEmpty(Model.AnhDaiDien)) {
                    <img src="@Model.AnhDaiDien" class="edit-avatar-preview" alt="Avatar" />
                }
                <h2 class="form-title">Cập nhật thông tin</h2>
                <p class="text-muted">Chỉnh sửa hồ sơ khách hàng: <strong>@Model.Ten</strong></p>
            </div>

            <div class="divider"></div>

            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 border-right">
                        <h6 class="text-uppercase font-weight-bold text-muted mb-3">Thông tin cá nhân</h6>
                        <div class="form-group">
                            <label asp-for="Ten" class="control-label">Họ và tên</label>
                            <input asp-for="Ten" class="form-control" />
                            <span asp-validation-for="Ten" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="SDT" class="control-label">Số điện thoại</label>
                            <input asp-for="SDT" class="form-control" />
                            <span asp-validation-for="SDT" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Email" class="control-label">Email</label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Gioi_Tinh" class="control-label">Giới tính</label>
                            <select asp-for="Gioi_Tinh" class="form-control">
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                            <span asp-validation-for="Gioi_Tinh" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 pl-md-4">
                        <h6 class="text-uppercase font-weight-bold text-muted mb-3">Tài khoản & Hình ảnh</h6>
                        <div class="form-group">
                            <label asp-for="AnhDaiDien" class="control-label">Link ảnh đại diện</label>
                            <input asp-for="AnhDaiDien" class="form-control" />
                            <span asp-validation-for="AnhDaiDien" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Ngay_Sinh" class="control-label">Ngày sinh</label>
                            <input asp-for="Ngay_Sinh" class="form-control" type="date" />
                            <span asp-validation-for="Ngay_Sinh" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Mat_Khau" class="control-label">Mật khẩu mới (nếu cần)</label>
                            <input asp-for="Mat_Khau" class="form-control" type="password" />
                            <span asp-validation-for="Mat_Khau" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Ngay_Tao" class="control-label">Ngày tạo</label>
                            <input asp-for="Ngay_Tao" class="form-control" readonly style="background: #f1f4f8;" />
                        </div>
                    </div>
                </div>

                <div class="form-group mt-3">
                    <div class="custom-control custom-switch">
                        <input type="checkbox" class="custom-control-input" asp-for="Trang_Thai" id="statusSwitch">
                        <label class="custom-control-label font-weight-600" for="statusSwitch">Kích hoạt tài khoản</label>
                    </div>
                </div>

                <div class="divider"></div>

                <button type="submit" class="btn-submit">
                    <i class="fas fa-save mr-2"></i> Cập nhật thay đổi
                </button>
            </form>

            <a asp-action="Index" class="back-link">
                <i class="fas fa-chevron-left mr-1"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}